---
import Layout from '../layouts/Layout.astro';

// Add your photo filenames to public/gallery/ folder
// e.g. public/gallery/photo-1.jpg, public/gallery/photo-2.jpg, etc.
const photos = [
  { src: "/gallery/photo-1.jpg", alt: "Yilun Wang" },
  { src: "/gallery/photo-2.jpg", alt: "Yilun Wang" },
  { src: "/gallery/photo-3.jpg", alt: "Yilun Wang" },
  { src: "/gallery/photo-4.jpg", alt: "Yilun Wang" },
  { src: "/gallery/photo-5.jpg", alt: "Yilun Wang" },
  { src: "/gallery/photo-6.jpg", alt: "Yilun Wang" },
];
---

<Layout title="Gallery — Yilun Wang" description="Photos of Yilun Wang">
  <section>
    <h2>Gallery</h2>
    <div class="grid">
      {photos.map((photo) => (
        <div class="photo-item">
          <img src={photo.src} alt={photo.alt} loading="lazy" />
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .photo-item img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    transition: opacity 0.2s;
  }

  .photo-item img:hover {
    opacity: 0.85;
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
