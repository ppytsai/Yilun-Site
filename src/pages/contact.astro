---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Yilun Wang" description="Contact Yilun Wang">
  <section class="contact">
    <h2>Contact</h2>
    <div class="contact-body">
      <p class="contact-line">
        <a href="mailto:info@yilunwang.art">info@yilunwang.art</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .contact {
    min-height: 50vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-body {
    margin-top: 1rem;
  }

  .contact-line {
    font-size: 1.2rem;
  }

  .contact-line a {
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 2px;
    transition: opacity 0.2s;
  }

  .contact-line a:hover {
    opacity: 0.5;
  }
</style>
